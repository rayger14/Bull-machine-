# ============================================================================
# Bull Machine .gitignore
# Enhanced version - 2025-11-14
# Repository restructuring - 2025-11-14
#
# Structure:
# - configs/{frozen,mvp,experiments,regime,bear}/
# - data/{processed,raw,archive}/
# - engine/strategies/archetypes/{bull,bear}/
# - tests/{unit,integration}/
# - docs/{technical,backtests,analysis,reports}/
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ----------------------------------------------------------------------------
# Build & Distribution
# ----------------------------------------------------------------------------
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ----------------------------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ----------------------------------------------------------------------------
# IDEs & Editors
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ----------------------------------------------------------------------------
# OS Files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Cache Directories
# ----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytest_cache/
.cache/
.dmypy.json
dmypy.json

# ----------------------------------------------------------------------------
# Bull Machine Specific - State
# ----------------------------------------------------------------------------
.bm_state.json

# ----------------------------------------------------------------------------
# Data Directories (Feature Stores, Cached Data)
# ----------------------------------------------------------------------------
data/**/*
!data/.gitkeep
!data/README.md

# Telemetry (large JSON masks)
telemetry/**/*
!telemetry/.gitkeep
!telemetry/README.md

# ----------------------------------------------------------------------------
# Results & Experiments (All experimental outputs gitignored)
# ----------------------------------------------------------------------------
results/**/*
!results/.gitkeep
!results/README.md
!results/bench_v2/
results/bench_v2/**/*
!results/bear_patterns/
results/bear_patterns/**/*

# Allow curated reference results (ground truth)
!results_reference/
!results_reference/**/*

# Allow specific production benchmarks if needed
# !results/production/

# ----------------------------------------------------------------------------
# Logs (All logs gitignored except structure)
# ----------------------------------------------------------------------------
logs/**/*
!logs/.gitkeep
!logs/README.md
!logs/paper_trading/
logs/paper_trading/**/*

# ----------------------------------------------------------------------------
# Reports (Optuna trials, optimization outputs)
# ----------------------------------------------------------------------------
# Root /reports directory removed - all reports now in docs/reports/
reports/**/*
!reports/.gitkeep
!reports/README.md

# Archive experimental reports (only curated reports tracked)
docs/reports/archive/**/*
!docs/reports/archive/README.md

# ----------------------------------------------------------------------------
# Models (ML Artifacts)
# ----------------------------------------------------------------------------
models/**/*
!models/.gitkeep
!models/README.md

# ----------------------------------------------------------------------------
# Profiles
# ----------------------------------------------------------------------------
profiles/**/*
*.prof
*_profile.txt

# ----------------------------------------------------------------------------
# Root-Level Experimental Outputs (Prevent future accumulation)
# ----------------------------------------------------------------------------

# Backtest Results
/*_backtest_results*.json
/*_results*.json
/*_validation*.json
/*_optimization*.json
/*_fine_grid*.json
/*_comparison*.csv
/*_training*.json
/*_candidates*.jsonl

# Signal & Decision Logs
/hybrid_signals_*.jsonl
/decision_log*.jsonl
/fusion_*.jsonl
/signal_blocks*.jsonl
/open_fail*.jsonl
/open_ok*.jsonl

# Health & Portfolio Summaries
/health_summary_*.json
/portfolio_summary_*.json

# Sweep Results
/sweep_results_*.json
/sweep_parameters*.json
/threshold_sensitivity_sweep*.csv

# ----------------------------------------------------------------------------
# Root-Level Scripts (Prevent experimental scripts in root)
# ----------------------------------------------------------------------------
/test_*.py
/sweep_*.py
/analyze_*.py
/download_*.py
/check_*.py
/diagnose_*.py
/debug_*.py
/monitor_*.sh
/optimize_all.sh
/WATCH_*.sh

# ----------------------------------------------------------------------------
