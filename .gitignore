# ----------------------------------------------------------------------------
/*.log
/q3_2024*.log
/monitor_output.log
/full_year_test_output.log

# Config patches
/config_patch_*.json
/exit_cfg_applied.json
/*_cfg_applied.json

# Temporary utilities
/engine_factory.py
/bull_machine_config.py
/institutional_testing_results.json

# ----------------------------------------------------------------------------
# Backup Files (2025-12-19)
# ----------------------------------------------------------------------------
*.bak
*.backup
*_backup_*
*.backup_before_*

# ----------------------------------------------------------------------------
# Test Output Files (2025-12-19)
# ----------------------------------------------------------------------------
*_validation_output.txt
*_test_output.txt
multi_regime_test_output.txt

# ----------------------------------------------------------------------------
# Optuna Databases (2025-12-19)
# ----------------------------------------------------------------------------
optuna_*.db
optuna_*.db-shm
optuna_*.db-wal

# ----------------------------------------------------------------------------
# Archive (Optional - uncomment if you want to gitignore)
# ----------------------------------------------------------------------------
# archive/

