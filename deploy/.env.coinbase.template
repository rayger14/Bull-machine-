# Coinbase Advanced Trade API credentials
# Get these from: https://portal.cdp.coinbase.com/access/api
# Leave empty for public-only access (paper trading works without auth)
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Optional: INTX API for funding rates (may use different credentials)
COINBASE_INTX_API_KEY=
COINBASE_INTX_API_SECRET=
COINBASE_INTX_PASSPHRASE=

# CoinGlass API key (for institutional derivatives data)
# Required for OI, funding, L/S ratio, taker data on US servers (Binance is geo-blocked)
# Get from: https://www.coinglass.com/account ($29/month Hobbyist tier)
COINGLASS_API_KEY=
