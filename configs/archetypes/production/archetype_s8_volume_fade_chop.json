  },
  "feature_flags": {
    "enable_wyckoff": true,
    "enable_smc": true,
    "enable_temporal": true,
    "enable_hob": true,
    "enable_fusion": true,
    "enable_macro": true,
    "use_temporal_confluence": true,
    "use_fusion_layer": true,
    "use_macro_regime": true,
