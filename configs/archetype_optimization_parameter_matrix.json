        "prune_if": "PF < 1.0",
        "keep_fraction": 0.50
      },
      "L2_3month": {
        "period": "2024-07-01 to 2024-09-30",
        "prune_if": "PF < 1.3 OR trades < 10",
        "keep_fraction": 0.20
      },
      "L3_9month": {
        "period": "2024-01-01 to 2024-09-30",
        "prune_if": "full scoring function",
        "keep_top_n": 5
      },
      "L4_oos": {
        "period": "2024-10-01 to 2024-12-31",
        "prune_if": "degradation > 30%",
        "keep_top_n": 1
      }
    }
  },
  "scoring_function": {
    "formula": "score = (pf_score * 0.40 + sharpe_score * 0.25 + regime_score * 0.15) - (dd_penalty * 0.12 + trade_penalty * 0.08)",
    "components": {
      "pf_score": {
        "formula": "(pf / target_pf) ** 1.5",
        "weight": 0.40,
        "note": "Exponential reward for exceeding target"
      },
      "sharpe_score": {
        "formula": "max(0, sharpe / 1.5)",
        "weight": 0.25,
        "note": "Linear scaling, target Sharpe = 1.5"
      },
      "regime_score": {
        "formula": "regime_multipliers[current_regime]",
        "weight": 0.15,
        "note": "Bull archetypes boosted in risk_on, bear in risk_off"
      },
      "dd_penalty": {
        "formula": "((dd - dd_threshold) / dd_threshold) ** 2 if dd > threshold else 0",
        "weight": 0.12,
        "note": "Quadratic penalty for exceeding DD threshold"
      },
      "trade_penalty": {
        "formula": "((trades - threshold) / threshold) ** 2 if outside [min, max] else 0",
        "weight": 0.08,
        "note": "Quadratic penalty for too few/many trades"
      }
    },
    "hard_constraints": {
      "negative_pf": -1000,
      "catastrophic_dd": -1000,
      "insufficient_trades": -1000
    }
  }
}
