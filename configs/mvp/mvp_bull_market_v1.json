{
  "version": "mvp_bull_market_v1",
  "profile": "bull_market_optimized",
  "description": "Optimized for 2024-like bull market conditions (PF target: 3-6)",
  "_fix_notes": "CRITICAL FIX: Added fusion_adapt.enable=true and regime_override to enable config-specific parameters. Without this, backtest defaults to static mode and ignores all config settings.",

  "fusion_adapt": {
    "enable": true,
    "ema_alpha": 0.2,
    "min_weight": 0.05
  },

  "regime_classifier": {
    "model_path": "models/regime_classifier_gmm.pkl",
    "feature_order": [
      "VIX",
      "DXY",
      "MOVE",
      "YIELD_2Y",
      "YIELD_10Y",
      "USDT.D",
      "BTC.D",
      "TOTAL",
      "TOTAL2",
      "funding",
      "oi",
      "rv_20d",
      "rv_60d"
    ],
    "zero_fill_missing": false,
    "regime_override": {
      "_comment": "Force 2024 as risk_on for validation testing",
      "2024": "risk_on"
    }
  },

  "ml_filter": {
    "enabled": true,
    "model_path": "models/btc_trade_quality_filter_v1.pkl",
    "threshold": 0.283
  },

  "fusion": {
    "entry_threshold_confidence": 0.40,
    "weights": {
      "wyckoff": 0.44,
      "liquidity": 0.23,
      "momentum": 0.33,
      "smc": 0.0
    }
  },

  "archetypes": {
    "use_archetypes": true,

    "max_trades_per_day": 3,

    "monthly_share_cap": {
      "trap_within_trend": 0.60,
      "order_block_retest": 0.30,
      "bos_choch_reversal": 0.15,
      "failed_rally": 0.05,
      "long_squeeze": 0.05
    },

    "enable_A": true,
    "enable_B": true,
    "enable_C": true,
    "enable_D": false,
    "enable_E": false,
    "enable_F": false,
    "enable_G": true,
    "enable_H": true,
    "enable_K": true,
    "enable_L": true,
    "enable_M": false,
    "enable_S1": false,
    "enable_S2": false,
    "_comment_S2": "Failed Rally DISABLED - PF 0.48 after optimization, pattern fundamentally broken",
    "enable_S3": false,
    "enable_S4": false,
    "enable_S5": false,
    "_comment_S5": "S5 (Long Squeeze) moved to bear config for architectural separation",
    "enable_S6": false,
    "enable_S7": false,
    "enable_S8": false,

    "thresholds": {
      "min_liquidity": 0.30,
      "trap_within_trend": {
        "direction": "long",
        "fusion_threshold": 0.42,
        "max_risk_pct": 0.02,
        "atr_stop_mult": 1.8
      },
      "order_block_retest": {
        "direction": "long",
        "fusion_threshold": 0.40,
        "max_risk_pct": 0.02,
        "atr_stop_mult": 1.8
      },
      "bos_choch_reversal": {
        "direction": "long",
        "fusion_threshold": 0.45,
        "max_risk_pct": 0.02,
        "atr_stop_mult": 1.8
      },
      "wick_trap_moneytaur": {
        "direction": "long",
        "fusion_threshold": 0.44,
        "max_risk_pct": 0.02,
        "atr_stop_mult": 1.8
      },
      "failed_rally": {
        "direction": "short",
        "fusion_threshold": 0.48,
        "rsi_min": 70,
        "vol_z_max": 0.5,
        "max_risk_pct": 0.015,
        "atr_stop_mult": 2.0
      },
      "long_squeeze": {
        "direction": "short",
        "fusion_threshold": 0.50,
        "funding_z_min": 2.0,
        "rsi_min": 75,
        "liquidity_max": 0.20,
        "max_risk_pct": 0.015,
        "atr_stop_mult": 3.0,
        "_comment": "Crisis-only pattern for bull config: Stricter thresholds than bear config"
      }
    },

    "trap_within_trend": {
      "archetype_weight": 1.2,
      "final_fusion_gate": 0.42,
      "cooldown_bars": 16
    },

    "order_block_retest": {
      "archetype_weight": 1.1,
      "final_fusion_gate": 0.40,
      "cooldown_bars": 12
    },

    "bos_choch_reversal": {
      "archetype_weight": 1.0,
      "final_fusion_gate": 0.45,
      "cooldown_bars": 14
    },

    "wick_trap_moneytaur": {
      "archetype_weight": 1.1,
      "final_fusion_gate": 0.44,
      "cooldown_bars": 10
    },

    "failed_rally": {
      "archetype_weight": 0.4,
      "final_fusion_gate": 0.48,
      "cooldown_bars": 8
    },

    "long_squeeze": {
      "archetype_weight": 0.5,
      "final_fusion_gate": 0.50,
      "cooldown_bars": 8,
      "_comment": "Low weight for crisis scenarios only"
    },

    "routing": {
      "risk_on": {
        "weights": {
          "trap_within_trend": 1.3,
          "order_block_retest": 1.4,
          "bos_choch_reversal": 1.2,
          "failed_rally": 0.0,
          "long_squeeze": 0.2
        },
        "final_gate_delta": 0.0,
        "_comment": "S2 disabled, S5 minimal for rare volatility spikes"
      },
      "neutral": {
        "weights": {
          "trap_within_trend": 1.0,
          "order_block_retest": 1.0,
          "bos_choch_reversal": 1.0,
          "failed_rally": 0.0,
          "long_squeeze": 0.5
        },
        "final_gate_delta": 0.01,
        "_comment": "S2 disabled, S5 moderate weight"
      },
      "risk_off": {
        "weights": {
          "trap_within_trend": 0.3,
          "order_block_retest": 0.4,
          "bos_choch_reversal": 0.5,
          "failed_rally": 0.0,
          "long_squeeze": 1.8
        },
        "final_gate_delta": 0.02,
        "_comment": "S2 disabled, S5 active for bear periods"
      },
      "crisis": {
        "weights": {
          "trap_within_trend": 0.1,
          "order_block_retest": 0.2,
          "bos_choch_reversal": 0.3,
          "failed_rally": 0.0,
          "long_squeeze": 2.5
        },
        "final_gate_delta": 0.04,
        "_comment": "S2 disabled, S5 primary crisis pattern"
      }
    },

    "exits": {
      "trap_within_trend": {
        "trail_atr": 1.3,
        "time_limit_hours": 78
      },
      "order_block_retest": {
        "trail_atr": 1.4,
        "time_limit_hours": 84
      },
      "bos_choch_reversal": {
        "trail_atr": 1.5,
        "time_limit_hours": 96
      },
      "wick_trap_moneytaur": {
        "trail_atr": 1.0,
        "time_limit_hours": 48
      },
      "failed_rally": {
        "trail_atr": 1.0,
        "time_limit_hours": 48
      },
      "long_squeeze": {
        "trail_atr": 0.8,
        "time_limit_hours": 24
      }
    }
  },

  "pnl_tracker": {
    "leverage": 5.0,
    "risk_per_trade": 0.02,
    "exits": {
      "enable_partial": true,
      "scale_out_rr": 1.0,
      "scale_out_pct": 0.5,
      "trail_atr_mult": 1.25
    }
  },

  "context": {
    "crisis_fuse": {
      "enabled": true,
      "lookback_hours": 24,
      "allow_one_trade_if_fusion_confidence_ge": 0.8
    }
  },

  "risk": {
    "base_risk_pct": 0.02,
    "max_position_size_pct": 0.20,
    "max_portfolio_risk_pct": 0.10
  },

  "feature_flags": {
    "enable_wyckoff": true,
    "enable_smc": true,
    "enable_temporal": true,
    "enable_hob": true,
    "enable_fusion": true,
    "enable_macro": true,
    "use_temporal_confluence": true,
    "use_fusion_layer": true,
    "use_macro_regime": true,
    "_comment": "All 6 domain engines enabled for bull archetypes (A, B, C, G, H, K, L)"
  }
}
