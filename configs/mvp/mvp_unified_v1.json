      "order_block_retest": {
        "trail_atr": 1.4,
        "time_limit_hours": 84
      },
      "bos_choch_reversal": {
        "trail_atr": 1.5,
        "time_limit_hours": 96
      },
      "wick_trap_moneytaur": {
        "trail_atr": 1.0,
        "time_limit_hours": 48
      },
      "long_squeeze": {
        "trail_atr": 1.2,
        "time_limit_hours": 24,
