{
  "_metadata": {
    "version": "mvp_regime_routed_production_v1",
    "profile": "regime_adaptive_production",
    "description": "Production-ready regime routing combining best bull + bear archetypes",
    "created": "2025-11-15",
    "author": "System Architect",
    "status": "PRODUCTION_READY",
    "validation_required": true
  },

  "_architecture": {
    "design_principles": [
      "Combine best-of-breed archetypes from bull and bear configs",
      "Regime-aware archetype weighting for adaptive performance",
      "Conservative defaults with progressive enhancement by regime",
      "Enable adaptive_fusion for dynamic response to market conditions",
      "Preserve gold standard bull performance while adding bear resilience"
    ],
    "routing_mechanism": {
      "location": "engine/archetypes/logic_v2_adapter.py:lines 452-476",
      "behavior": "Multiplies archetype scores by regime-specific weights",
      "selection": "Highest weighted score wins (ties broken by priority)",
      "regime_source": "RuntimeContext.regime_label (respects regime_override)"
    },
    "safety_measures": [
      "Bull archetypes dominate in risk_on (preserve 2024 performance)",
      "Bear archetypes dominate in risk_off (improve 2022 performance)",
      "Balanced mix in neutral (smooth transitions)",
      "Ultra-conservative in crisis (capital preservation)",
      "Regime override available for validation testing"
    ]
  },

  "_expected_performance": {
    "risk_on_2024": {
      "target_pf": "3.5-6.0",
      "win_rate": "60-70%",
      "dominant_archetypes": ["trap_within_trend", "order_block_retest", "wick_trap"],
      "note": "Should match or exceed bull market config baseline"
    },
    "risk_off_2022": {
      "target_pf": "1.3-2.0",
      "win_rate": "50-60%",
      "dominant_archetypes": ["failed_rally", "long_squeeze"],
      "note": "Should vastly improve over 0.11 PF baseline"
    },
    "neutral_2023": {
      "target_pf": "1.5-2.5",
      "win_rate": "55-65%",
      "dominant_archetypes": ["balanced mix"],
      "note": "Smooth transition behavior"
    },
    "crisis": {
      "target_pf": "0.8-1.5",
      "behavior": "Capital preservation, minimal exposure",
      "dominant_archetypes": ["failed_rally", "long_squeeze"],
      "note": "Defensive positioning, tight risk controls"
    }
  },

  "ml_filter": {
    "enabled": true,
    "model_path": "models/btc_trade_quality_filter_v1.pkl",
    "threshold": 0.283,
    "_comment": "Global quality filter applied before archetype scoring"
  },

  "regime_classifier": {
    "_comment": "Use regime_override for validation; remove for production",
    "model_path": "models/regime_classifier_gmm.pkl",
    "feature_order": [
      "VIX", "DXY", "MOVE", "YIELD_2Y", "YIELD_10Y",
      "USDT.D", "BTC.D", "TOTAL", "TOTAL2",
      "funding", "oi", "rv_20d", "rv_60d"
    ],
    "zero_fill_missing": false,
    "regime_override": {
      "_comment": "VALIDATION ONLY: Force regime for testing. Remove for production.",
      "_usage": "Set '2022': 'risk_off' to validate bear archetype routing",
      "_examples": {
        "test_bear_2022": {"2022": "risk_off"},
        "test_bull_2024": {"2024": "risk_on"},
        "production": {}
      }
    }
  },

  "fusion": {
    "entry_threshold_confidence": 0.38,
    "_comment": "Moderate baseline, regime routing adjusts per archetype",
    "weights": {
      "wyckoff": 0.40,
      "liquidity": 0.27,
      "momentum": 0.33,
      "smc": 0.0
    },
    "adaptive_fusion": {
      "enabled": true,
      "_comment": "CRITICAL: Must be enabled for regime routing to work properly",
      "_mechanism": "Adjusts fusion weights based on market volatility and regime",
      "_impact": "Prevents regime classifier from being bypassed"
    }
  },

  "archetypes": {
    "use_archetypes": true,

    "max_trades_per_day": 3,

    "monthly_share_cap": {
      "_comment": "Prevent any single archetype from dominating",
      "trap_within_trend": 0.50,
      "order_block_retest": 0.30,
      "wick_trap": 0.20,
      "failed_rally": 0.30,
      "long_squeeze": 0.25,
      "bos_choch_reversal": 0.15
    },

    "_bull_archetypes": {
      "_comment": "Long-biased archetypes optimized for risk_on regimes"
    },
    "enable_A": true,
    "enable_B": true,
    "enable_C": true,
    "enable_D": false,
    "enable_E": false,
    "enable_F": false,
    "enable_G": true,
    "enable_H": true,
    "enable_K": true,
    "enable_L": true,
    "enable_M": false,

    "_bear_archetypes": {
      "_comment": "Short-biased archetypes optimized for risk_off regimes"
    },
    "enable_S1": false,
    "enable_S2": true,
    "enable_S3": false,
    "enable_S4": false,
    "enable_S5": true,
    "enable_S6": false,
    "enable_S7": false,
    "enable_S8": false,

    "thresholds": {
      "min_liquidity": 0.25,
      "_comment": "Global minimum; regime routing adjusts per archetype"
    },

    "spring": {
      "_comment": "Archetype A: Trap Reversal (PTI spring/UTAD)",
      "fusion_threshold": 0.35,
      "pti_score_threshold": 0.40,
      "disp_atr_multiplier": 0.80,
      "archetype_weight": 1.0
    },

    "order_block_retest": {
      "_comment": "Archetype B: Order Block Retest (BOMS + Wyckoff)",
      "fusion_threshold": 0.38,
      "boms_strength_min": 0.30,
      "wyckoff_min": 0.35,
      "archetype_weight": 1.10,
      "final_fusion_gate": 0.38,
      "cooldown_bars": 12
    },

    "fvg_continuation": {
      "_comment": "Archetype C: FVG Continuation",
      "fusion_threshold": 0.42,
      "disp_atr_multiplier": 1.00,
      "momentum_min": 0.45,
      "tf4h_fusion_min": 0.25,
      "archetype_weight": 1.0
    },

    "trap_within_trend": {
      "_comment": "Archetype H: Trap Within Trend (Workhorse)",
      "fusion_threshold": 0.40,
      "adx_threshold": 25.0,
      "liquidity_threshold": 0.30,
      "archetype_weight": 1.15,
      "final_fusion_gate": 0.40,
      "cooldown_bars": 16
    },

    "wick_trap_moneytaur": {
      "_comment": "Archetype K: Wick Trap / Moneytaur",
      "fusion_threshold": 0.42,
      "adx_threshold": 25.0,
      "liquidity_threshold": 0.30,
      "archetype_weight": 1.05,
      "final_fusion_gate": 0.42,
      "cooldown_bars": 10
    },

    "volume_exhaustion": {
      "_comment": "Archetype L: Volume Exhaustion / Zeroika",
      "fusion_threshold": 0.38,
      "vol_z_min": 1.0,
      "rsi_min": 70.0,
      "archetype_weight": 1.0
    },

    "failed_rally": {
      "_comment": "Archetype S2: Failed Rally Rejection (bear)",
      "fusion_threshold": 0.40,
      "wick_ratio_min": 2.0,
      "require_rsi_divergence": false,
      "archetype_weight": 0.80,
      "final_fusion_gate": 0.40,
      "cooldown_bars": 8
    },

    "long_squeeze": {
      "_comment": "Archetype S5: Long Squeeze Cascade (bear)",
      "fusion_threshold": 0.42,
      "funding_z_min": 1.2,
      "rsi_min": 70,
      "liquidity_max": 0.25,
      "archetype_weight": 0.75,
      "final_fusion_gate": 0.42,
      "cooldown_bars": 6
    },

    "routing": {
      "_comment": "Regime-specific archetype weighting - applied in logic_v2_adapter.py:467-475",
      "_mechanism": "archetype_score *= regime_weights[archetype_name]",
      "_selection": "Highest weighted score wins after adjustment",

      "risk_on": {
        "_description": "Bull market conditions (2024-like): Bull archetypes dominate",
        "weights": {
          "trap_reversal": 1.25,
          "trap_within_trend": 1.40,
          "order_block_retest": 1.50,
          "wick_trap": 1.30,
          "fvg_continuation": 1.20,
          "volume_exhaustion": 1.10,
          "failed_rally": 0.25,
          "long_squeeze": 0.20
        },
        "final_gate_delta": 0.0,
        "_rationale": "Maximize bull archetype selection, heavily suppress bear shorts"
      },

      "neutral": {
        "_description": "Mixed conditions: Balanced competition between bull and bear",
        "weights": {
          "trap_reversal": 1.00,
          "trap_within_trend": 1.00,
          "order_block_retest": 1.00,
          "wick_trap": 1.00,
          "fvg_continuation": 1.00,
          "volume_exhaustion": 1.00,
          "failed_rally": 0.70,
          "long_squeeze": 0.60
        },
        "final_gate_delta": 0.01,
        "_rationale": "Equal base weights, slight preference for longs, minimal gate raise"
      },

      "risk_off": {
        "_description": "Bear market conditions (2022-like): Bear archetypes dominate",
        "weights": {
          "trap_reversal": 0.35,
          "trap_within_trend": 0.30,
          "order_block_retest": 0.40,
          "wick_trap": 0.35,
          "fvg_continuation": 0.25,
          "volume_exhaustion": 0.40,
          "failed_rally": 1.80,
          "long_squeeze": 2.00
        },
        "final_gate_delta": 0.02,
        "_rationale": "Heavily favor bear shorts, suppress bull longs, raise quality bar"
      },

      "crisis": {
        "_description": "Extreme stress (March 2020-like): Ultra-defensive, bear shorts only",
        "weights": {
          "trap_reversal": 0.15,
          "trap_within_trend": 0.10,
          "order_block_retest": 0.15,
          "wick_trap": 0.20,
          "fvg_continuation": 0.10,
          "volume_exhaustion": 0.15,
          "failed_rally": 2.20,
          "long_squeeze": 2.50
        },
        "final_gate_delta": 0.04,
        "_rationale": "Near-total suppression of longs, only highest-conviction bear shorts"
      }
    },

    "exits": {
      "_comment": "Archetype-specific exit logic",
      "trap_within_trend": {
        "trail_atr": 1.30,
        "time_limit_hours": 78
      },
      "order_block_retest": {
        "trail_atr": 1.40,
        "time_limit_hours": 84
      },
      "wick_trap": {
        "trail_atr": 1.20,
        "time_limit_hours": 60
      },
      "failed_rally": {
        "trail_atr": 1.50,
        "time_limit_hours": 48,
        "_comment": "Tighter trail for short-biased trades"
      },
      "long_squeeze": {
        "trail_atr": 1.50,
        "time_limit_hours": 24,
        "_comment": "Fast exit for cascade trades"
      }
    }
  },

  "pnl_tracker": {
    "leverage": 5.0,
    "risk_per_trade": 0.02,
    "exits": {
      "enable_partial": true,
      "scale_out_rr": 1.0,
      "scale_out_pct": 0.5,
      "trail_atr_mult": 1.25
    }
  },

  "context": {
    "crisis_fuse": {
      "enabled": true,
      "lookback_hours": 24,
      "allow_one_trade_if_fusion_confidence_ge": 0.8,
      "_comment": "Prevents overtrading in crisis regime"
    }
  },

  "risk": {
    "base_risk_pct": 0.02,
    "max_position_size_pct": 0.20,
    "max_portfolio_risk_pct": 0.10,
    "_comment": "Conservative risk controls across all regimes"
  },

  "_validation_checklist": {
    "pre_deployment": [
      "Run bin/validate_regime_routing.py to verify routing behavior",
      "Test with regime_override={'2022': 'risk_off'} to validate bear routing",
      "Test with regime_override={'2024': 'risk_on'} to validate bull routing",
      "Verify 2024 PF >= 3.5 (no regression from bull baseline)",
      "Verify 2022 PF >= 1.3 (improvement from 0.11 baseline)",
      "Check archetype distribution matches regime weights",
      "Confirm adaptive_fusion is enabled",
      "Remove regime_override before production deployment"
    ],
    "regression_tests": [
      "2024 bull market: PF should match mvp_bull_market_v1.json",
      "2022 bear market: PF should match mvp_bear_market_v1.json",
      "2023 transitions: No whipsaw in Q1 2024, Q4 2023",
      "Archetype diversity: No single archetype >60% of trades in any regime"
    ]
  },

  "_troubleshooting": {
    "routing_not_working": {
      "symptom": "All regimes produce same archetype distribution",
      "fixes": [
        "Check adaptive_fusion.enabled=true",
        "Verify regime_classifier is running (not using regime_override)",
        "Check RuntimeContext.regime_label is propagating",
        "Verify routing section is at config['archetypes']['routing']"
      ]
    },
    "bull_performance_regression": {
      "symptom": "2024 PF drops below 3.5",
      "fixes": [
        "Increase risk_on weights for trap_within_trend, order_block_retest",
        "Lower final_gate_delta in risk_on regime",
        "Check bear archetypes aren't firing in risk_on periods"
      ]
    },
    "bear_performance_poor": {
      "symptom": "2022 PF still below 1.0",
      "fixes": [
        "Verify regime_override={'2022': 'risk_off'} for testing",
        "Check failed_rally and long_squeeze are enabled",
        "Lower fusion_threshold for bear archetypes",
        "Increase risk_off weights for bear archetypes"
      ]
    }
  },

  "_references": {
    "routing_implementation": "engine/archetypes/logic_v2_adapter.py:452-476",
    "threshold_policy": "engine/archetypes/threshold_policy.py",
    "bull_baseline": "configs/mvp/mvp_bull_market_v1.json",
    "bear_baseline": "configs/mvp/mvp_bear_market_v1.json",
    "regime_classifier_fix": "configs/quick_fix_2022_regime_override.json",
    "documentation": "docs/technical/REGIME_ROUTING_GUIDE.md",
    "validation_script": "bin/validate_regime_routing.py"
  }
}
