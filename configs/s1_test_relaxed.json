{
  "version": "s1_test_relaxed",
  "profile": "S1 Liquidity Vacuum - RELAXED TEST CONFIG",
  "description": "S1 test config with relaxed thresholds for baseline comparison. NOT FOR PRODUCTION.",

  "_comment": "This is a TEST config with relaxed thresholds to ensure S1 generates trades for comparison. Production config (s1_v2_production.json) has stricter filters.",

  "adaptive_fusion": false,

  "regime_classifier": {
    "model_path": "models/regime_classifier_gmm.pkl",
    "feature_order": [
      "VIX", "DXY", "MOVE", "YIELD_2Y", "YIELD_10Y",
      "USDT.D", "BTC.D", "TOTAL", "TOTAL2",
      "funding", "oi", "rv_20d", "rv_60d"
    ],
    "zero_fill_missing": false,
    "regime_override": {}
  },

  "ml_filter": {
    "enabled": false
  },

  "fusion": {
    "entry_threshold_confidence": 1.0,
    "weights": {
      "wyckoff": 0.0,
      "liquidity": 0.0,
      "momentum": 0.0,
      "smc": 0.0
    }
  },

  "risk": {
    "base_risk_pct": 0.02,
    "max_position_size_pct": 0.20,
    "max_portfolio_risk_pct": 0.10
  },

  "archetypes": {
    "use_archetypes": true,
    "max_trades_per_day": 0,

    "enable_A": false,
    "enable_B": false,
    "enable_C": false,
    "enable_D": false,
    "enable_E": false,
    "enable_F": false,
    "enable_G": false,
    "enable_H": false,
    "enable_K": false,
    "enable_L": false,
    "enable_M": false,
    "enable_S1": true,
    "enable_S2": false,
    "enable_S3": false,
    "enable_S4": false,
    "enable_S5": false,
    "enable_S6": false,
    "enable_S7": false,
    "enable_S8": false,

    "thresholds": {
      "min_liquidity": 0.1,

      "liquidity_vacuum": {
        "direction": "long",
        "archetype_weight": 2.5,

        "use_v2_logic": true,
        "use_confluence": true,
        "use_regime_filter": false,
        "_comment_regime_filter": "DISABLED for testing - allows trades in any regime",

        "_comment_relaxed": "RELAXED THRESHOLDS FOR TESTING",
        "capitulation_depth_max": -0.10,
        "_note_relaxed_depth": "Lowered from -0.20 to -0.10 (10% drawdown) for testing",

        "crisis_composite_min": 0.20,
        "_note_relaxed_crisis": "Lowered from 0.35 to 0.20 for testing",

        "confluence_min_conditions": 2,
        "_note_relaxed_conditions": "Lowered from 3 to 2 conditions for testing",

        "confluence_threshold": 0.50,
        "_note_relaxed_confluence": "Lowered from 0.65 to 0.50 for testing",

        "confluence_weights": {
          "capitulation_depth_score": 0.20,
          "crisis_environment": 0.15,
          "volume_climax_3b": 0.08,
          "wick_exhaustion_3b": 0.07,
          "liquidity_drain_severity": 0.10,
          "liquidity_velocity_score": 0.08,
          "liquidity_persistence_score": 0.07,
          "funding_reversal": 0.12,
          "oversold": 0.08,
          "volatility_spike": 0.05
        },

        "volume_climax_3b_min": 0.30,
        "_note_relaxed_volume": "Lowered from 0.50 to 0.30 for testing",

        "wick_exhaustion_3b_min": 0.40,
        "_note_relaxed_wick": "Lowered from 0.60 to 0.40 for testing",

        "allowed_regimes": ["neutral", "risk_off", "crisis"],
        "_note_relaxed_regimes": "Added 'neutral' regime for testing (production only uses risk_off/crisis)",

        "drawdown_override_pct": 0.08,
        "_note_relaxed_override": "Lowered from 0.10 to 0.08 for testing",

        "require_regime_or_drawdown": false,
        "_note_regime_disabled": "Regime filter DISABLED for testing",

        "max_risk_pct": 0.02,
        "atr_stop_mult": 2.5,
        "cooldown_bars": 12,

        "fusion_threshold": 0.25,
        "_note_relaxed_fusion": "Lowered from 0.30 to 0.25 for testing"
      }
    },

    "exits": {
      "liquidity_vacuum": {
        "trail_atr": 2.0,
        "time_limit_hours": 72
      }
    },

    "routing": {
      "risk_on": {
        "weights": {"liquidity_vacuum": 1.0},
        "final_gate_delta": 0.0
      },
      "neutral": {
        "weights": {"liquidity_vacuum": 1.0},
        "final_gate_delta": 0.0
      },
      "risk_off": {
        "weights": {"liquidity_vacuum": 1.5},
        "final_gate_delta": 0.0
      },
      "crisis": {
        "weights": {"liquidity_vacuum": 2.0},
        "final_gate_delta": 0.0
      }
    }
  },

  "_test_metadata": {
    "created": "2025-12-03",
    "purpose": "TESTING ONLY - Relaxed thresholds for baseline comparison",
    "changes_from_production": [
      "capitulation_depth_max: -0.20 → -0.10",
      "crisis_composite_min: 0.35 → 0.20",
      "confluence_threshold: 0.65 → 0.50",
      "confluence_min_conditions: 3 → 2",
      "volume_climax_3b_min: 0.50 → 0.30",
      "wick_exhaustion_3b_min: 0.60 → 0.40",
      "allowed_regimes: added 'neutral'",
      "use_regime_filter: false (DISABLED)",
      "fusion_threshold: 0.30 → 0.25"
    ],
    "deployment_readiness": "TEST_ONLY - NOT FOR PRODUCTION"
  }
}
