{
  "_comment": "=================================================================",
  "_comment_2": "EXPERIMENT CONFIGURATION TEMPLATE",
  "_comment_3": "Standard template for quant testing framework",
  "_comment_4": "All models must use this schema for fair comparison",
  "_comment_5": "=================================================================",

  "experiment_id": "exp_template_v1",
  "description": "Template experiment configuration - copy and customize",
  "created_at": "2025-12-05T00:00:00Z",
  "version": "1.0",

  "_section_1": "═══════════════════════════════════════════════════════════",
  "_section_1_title": "ASSET CONFIGURATION",
  "_section_1_desc": "Define what to test (symbol, timeframe, data source)",

  "asset": {
    "symbol": "BTC",
    "timeframe": "1H",
    "data_source": "data/processed/features_mtf/BTC_1H_2020-01-01_to_2025-12-31.parquet",
    "required_features": [
      "_comment: List required features (validates before backtest)",
      "close", "high", "low", "volume",
      "atr_14", "rsi_14", "adx_14",
      "wyckoff_phase", "regime_label"
    ]
  },

  "_section_2": "═══════════════════════════════════════════════════════════",
  "_section_2_title": "TIME PERIOD SPLITS",
  "_section_2_desc": "Train, Test, Out-of-Sample (OOS) date ranges",

  "periods": {
    "train": {
      "start": "2020-01-01",
      "end": "2022-12-31",
      "description": "Training period (bull + bear cycle)",
      "expected_regime": "mixed",
      "_note": "Used to optimize/train models (if applicable)"
    },
    "test": {
      "start": "2023-01-01",
      "end": "2023-12-31",
      "description": "Test period (recovery/validation)",
      "expected_regime": "mixed",
      "_note": "First unseen data - primary performance metric"
    },
    "oos": {
      "start": "2024-01-01",
      "end": "2024-12-31",
      "description": "Out-of-sample period (final validation)",
      "expected_regime": "mixed",
      "_note": "Ultimate test - overfit detection"
    }
  },

  "_section_3": "═══════════════════════════════════════════════════════════",
  "_section_3_title": "REGIME FILTERING",
  "_section_3_desc": "Optional: Test models only in specific market regimes",

  "regime_filters": {
    "enabled": false,
    "modes": [
      "all",
      "risk_on",
      "risk_off",
      "crisis"
    ],
    "default": "all",
    "_note_modes": "all = no filter, others = test only in that regime",
    "_note_use_case": "Compare same model across regimes to find specialists"
  },

  "_section_4": "═══════════════════════════════════════════════════════════",
  "_section_4_title": "COST MODEL",
  "_section_4_desc": "Trading costs (slippage + fees) - CRITICAL for realism",

  "cost_model": {
    "slippage_bps": 5.0,
    "_slippage_note": "5 bps = 0.05% = realistic for BTC limit orders",

    "fee_bps": 6.0,
    "_fee_note": "6 bps = 0.06% = Binance maker/taker blend",

    "total_cost_bps": 11.0,
    "_total_note": "11 bps per round-trip (entry + exit)",

    "slippage_model": "fixed",
    "_slippage_model_options": ["fixed", "volume_weighted", "atrbased"],
    "_slippage_model_note": "fixed = simple, volume_weighted = more realistic",

    "_example_impact": "On $10k trade: $11 cost per round-trip"
  },

  "_section_5": "═══════════════════════════════════════════════════════════",
  "_section_5_title": "POSITION SIZING",
  "_section_5_desc": "Capital management rules",

  "position_sizing": {
    "initial_capital": 10000,
    "_initial_capital_note": "$10k is standard benchmark size",

    "risk_per_trade_pct": 1.0,
    "_risk_pct_note": "1% risk per trade (max loss if stop hit)",

    "max_leverage": 1.0,
    "_leverage_note": "1.0 = spot trading, 3.0 = 3x leverage",

    "compounding": true,
    "_compounding_note": "true = position size grows with equity, false = fixed size",

    "max_position_size_pct": 100.0,
    "_max_position_note": "100% = can go all-in (if 1.0 leverage), 50% = max half capital"
  },

  "_section_6": "═══════════════════════════════════════════════════════════",
  "_section_6_title": "STATISTICAL REQUIREMENTS",
  "_section_6_desc": "Minimum thresholds for valid results",

  "statistical_requirements": {
    "min_trades_train": 30,
    "_min_train_note": "Below 30 trades = not enough data to train",

    "min_trades_test": 20,
    "_min_test_note": "Below 20 trades = test metrics are noise",

    "min_trades_oos": 15,
    "_min_oos_note": "Below 15 trades = OOS could be luck",

    "min_confidence_level": 0.80,
    "_confidence_note": "0.80 = 80% confidence based on sample size",

    "min_sharpe_ratio": 1.0,
    "_sharpe_note": "Sharpe < 1.0 = poor risk-adjusted returns",

    "max_acceptable_drawdown_pct": 30.0,
    "_dd_note": "Max 30% drawdown tolerated",

    "_note": "Models failing these requirements are auto-flagged"
  },

  "_section_7": "═══════════════════════════════════════════════════════════",
  "_section_7_title": "ACCEPTANCE GATES",
  "_section_7_desc": "Pass/fail criteria (see RULES_OF_THE_LAB.md)",

  "acceptance_gates": {
    "gate_1_sample_size": {
      "enabled": true,
      "train_min": 30,
      "test_min": 20,
      "oos_min": 15
    },
    "gate_2_expectancy": {
      "enabled": true,
      "test_pf_min": 1.5,
      "oos_pf_min": 1.3,
      "require_costs": true
    },
    "gate_3_overfit": {
      "enabled": true,
      "max_overfit": 0.5,
      "_overfit_formula": "train_pf - test_pf",
      "max_degradation_pct": 30.0,
      "_degradation_formula": "(train_pf - oos_pf) / train_pf * 100"
    },
    "gate_4_baseline_superiority": {
      "enabled": true,
      "require_beat_on_test": true,
      "require_beat_on_oos": true,
      "_note": "Model must beat baselines on BOTH test and OOS"
    },
    "gate_5_risk_adjusted": {
      "enabled": true,
      "min_sharpe": 1.0,
      "max_drawdown_pct": 30.0,
      "min_calmar": 1.0
    },
    "gate_6_trade_quality": {
      "enabled": true,
      "min_win_rate_pct": 35.0,
      "min_avg_r": 0.3,
      "max_largest_loss_r": -3.0
    }
  },

  "_section_8": "═══════════════════════════════════════════════════════════",
  "_section_8_title": "OUTPUT CONFIGURATION",
  "_section_8_desc": "Where to save results and what format",

  "output": {
    "results_dir": "results/experiments",
    "save_trades": true,
    "trade_log_format": "parquet",
    "_trade_log_options": ["csv", "parquet", "both"],

    "save_metrics": true,
    "metrics_format": "json",
    "_metrics_options": ["json", "csv", "both"],

    "generate_comparison_report": true,
    "comparison_format": "markdown",
    "_comparison_options": ["markdown", "html", "pdf"],

    "save_plots": true,
    "plot_types": ["equity_curve", "drawdown", "monthly_returns", "trade_distribution"],

    "versioning": {
      "auto_increment": true,
      "_versioning_note": "Automatically append v2, v3 to avoid overwriting"
    }
  },

  "_section_9": "═══════════════════════════════════════════════════════════",
  "_section_9_title": "EXTENSIONS (Future)",
  "_section_9_desc": "Advanced features for later phases",

  "extensions": {
    "multi_asset": {
      "enabled": false,
      "assets": [
        {"symbol": "BTC", "weight": 0.50},
        {"symbol": "ETH", "weight": 0.30},
        {"symbol": "SOL", "weight": 0.20}
      ],
      "correlation_penalty": true,
      "max_concurrent_positions": 3,
      "_note": "Test portfolio performance across multiple assets"
    },

    "walk_forward": {
      "enabled": false,
      "window_months": 6,
      "step_months": 1,
      "min_windows": 5,
      "_note": "Rolling window validation for robustness testing"
    },

    "regime_slicing": {
      "enabled": false,
      "slices": [
        {"name": "risk_on", "filter": "regime_label == 'risk_on'"},
        {"name": "risk_off", "filter": "regime_label == 'risk_off'"},
        {"name": "crisis", "filter": "regime_label == 'crisis'"}
      ],
      "_note": "Test same model across different regimes separately"
    },

    "monte_carlo": {
      "enabled": false,
      "simulations": 1000,
      "randomize_entry_timing": true,
      "randomize_exit_fills": true,
      "_note": "Stress test with randomized execution to check robustness"
    }
  },

  "_section_10": "══════════════════════════════════════════════════════════",
  "_section_10_title": "METADATA",
  "_section_10_desc": "Tracking and documentation",

  "metadata": {
    "author": "Quant Team",
    "purpose": "Template for standardized model testing",
    "related_experiments": [],
    "tags": ["template", "btc", "1h", "quant_lab"],
    "notes": "Copy this template to create new experiments. Preserve original template."
  },

  "_footer": "═══════════════════════════════════════════════════════════",
  "_footer_note_1": "END OF TEMPLATE",
  "_footer_note_2": "See docs/QUANT_LAB_ARCHITECTURE.md for usage guide",
  "_footer_note_3": "See RULES_OF_THE_LAB.md for acceptance criteria"
}
