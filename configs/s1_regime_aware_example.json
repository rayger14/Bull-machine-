              "trades_per_year": 8.7,
              "sharpe_ratio": 2.41
            },
            "fusion_threshold": 0.42,
            "liquidity_max": 0.12,
            "volume_z_min": 2.2,
            "wick_lower_min": 0.32,
            "cooldown_bars": 10,
            "atr_stop_mult": 2.2
          }
