        "_validation_data": "2023-01-01 to 2023-06-30",

        "allowed_regimes": ["risk_off", "crisis"],

        "_comment_base": "Base thresholds (fallback when regime unavailable)",
        "fusion_threshold": 0.45,
        "liquidity_max": 0.15,
        "volume_z_min": 2.0,
        "wick_lower_min": 0.30,
        "cooldown_bars": 12,
        "atr_stop_mult": 2.5,

        "_comment_regime": "Per-regime optimized thresholds",
